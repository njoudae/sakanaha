# Saknaha production environment example.
# Use Vercel for VITE_* variables and Convex Cloud for server-side variables.
# Do not commit filled secrets.

# Frontend public variables - Vercel production
VITE_CONVEX_URL=https://your-production-deployment.convex.cloud
VITE_FEATURE_AUTH_CONVEX_AUTH_ENABLED=true
VITE_FEATURE_AUTH_GOOGLE_ENABLED=true
VITE_FEATURE_AUTH_EMAIL_OTP_ENABLED=true
VITE_FEATURE_AUTH_PHONE_OTP_ENABLED=false
VITE_FEATURE_DATA_CONVEX_ENABLED=false
VITE_FEATURE_DATA_DUAL_READ_ENABLED=false
VITE_FEATURE_DATA_DUAL_WRITE_ENABLED=false

# Convex Auth server variables - Convex production
CONVEX_SITE_URL=https://your-production-deployment.convex.site
SITE_URL=https://saknaha.example
JWT_PRIVATE_KEY=
JWKS=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_EMAIL_OTP_WEBHOOK_URL=
AUTH_EMAIL_OTP_WEBHOOK_SECRET=
AUTH_PHONE_OTP_ENABLED=false

# Provider selectors - Convex production
SAKNAHA_EMAIL_PROVIDER=webhook
SAKNAHA_PUSH_PROVIDER=disabled
SAKNAHA_ANALYTICS_PROVIDER=disabled
SAKNAHA_MONITORING_PROVIDER=disabled
SAKNAHA_STORAGE_PROVIDER=convex
SAKNAHA_COST_PROVIDER=convex

# Maps - Convex production
SAKNAHA_MAPS_PROVIDER=google
SAKNAHA_MAPS_PAID_CALLS_ENABLED=false
SAKNAHA_MAPS_CACHE_TTL_SECONDS=2592000
SAKNAHA_MAPS_QUOTA_PER_MINUTE=60
SAKNAHA_MAPS_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
SAKNAHA_MAPS_CIRCUIT_BREAKER_COOLDOWN_MS=300000
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=
OPENSTREETMAP_USER_AGENT=Saknaha Production

# SMS - Convex production
SAKNAHA_SMS_ENABLED=false
SAKNAHA_SMS_EMERGENCY_DISABLED=false
SAKNAHA_SMS_PROVIDER=msegat
SAKNAHA_SMS_FALLBACK_PROVIDERS=taqny,twilio
SAKNAHA_SMS_RETRY_COUNT=3
SAKNAHA_SMS_OTP_TTL_SECONDS=600
SAKNAHA_SMS_HOURLY_LIMIT=100
SAKNAHA_SMS_DAILY_LIMIT=500
SAKNAHA_SMS_PER_USER_HOURLY_LIMIT=5
SAKNAHA_SMS_PER_USER_DAILY_LIMIT=20
SAKNAHA_SMS_PER_IP_HOURLY_LIMIT=20
SAKNAHA_SMS_PER_IP_DAILY_LIMIT=100
SAKNAHA_SMS_DESTINATION_ACCOUNT_HOURLY_LIMIT=3
SAKNAHA_SMS_RETRY_BASE_DELAY_MS=500
SAKNAHA_SMS_RETRY_MAX_DELAY_MS=30000
SAKNAHA_SMS_FAILURE_RATE_DISABLE_THRESHOLD=0.5
SAKNAHA_SMS_HEALTH_MINIMUM_SAMPLE_SIZE=5
SAKNAHA_SMS_HEALTH_WINDOW_SIZE=50
SAKNAHA_SMS_CIRCUIT_BREAKER_COOLDOWN_MS=300000
SAKNAHA_SMS_MSEGAT_ESTIMATED_COST=0.03
SAKNAHA_SMS_TAQNY_ESTIMATED_COST=0.03
SAKNAHA_SMS_TWILIO_ESTIMATED_COST=0.04
SAKNAHA_SMS_COST_CURRENCY=SAR
SAKNAHA_SMS_OTP_TEMPLATE=Your Saknaha verification code is {{code}}.

# SMS provider credentials - Convex production
MSEGAT_USERNAME=
MSEGAT_API_KEY=
MSEGAT_SENDER=
MSEGAT_ENDPOINT=
TAQNY_BEARER_TOKEN=
TAQNY_SENDER=
TAQNY_ENDPOINT=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_ENDPOINT=

# Storage - Convex production
SAKNAHA_STORAGE_MAX_UPLOAD_BYTES=10485760

# Planned integrations, not consumed by runtime code yet
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=
