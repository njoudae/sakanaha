{
  "name": "saknaha-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "convex": "^1.42.1"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@saknaha/web",
    "build": "turbo run build",
    "build:all": "turbo run build",
    "preview": "turbo run preview --filter=@saknaha/web",
    "lint": "eslint convex && turbo run lint",
    "lint:fix": "eslint convex --fix && turbo run lint:fix",
    "typecheck": "tsc -b",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "convex:codegen": "convex codegen --typecheck disable",
    "convex:dev": "convex dev",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "turbo": "^2.6.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
